@page
@model RegisterModel
@{
    ViewData["Title"] = "Rejestracja";
}

<div class="w-full h-full flex items-center justify-center">
    <section class="flex flex-col gap-2">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div class="text-center">
                <h2>Rejestracja</h2>
            </div>
            <div class="pr-2 pl-2 flex justify-center">
                <hr class="w-48 h-1 bg-gray-100 border-0 rounded dark:bg-gray-700">
            </div>
            <div asp-validation-summary="ModelOnly" class="" role="alert"></div>
            <div class="3">
                <input asp-for="Input.Email" class="" autocomplete="username" aria-required="true" placeholder="name@example.com"/>
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class=""></span>
            </div>
            <div class="">
                <input asp-for="Input.Password" class="" autocomplete="new-password" aria-required="true" placeholder="password"/>
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class=""></span>
            </div>
            <div class="">
                <input asp-for="Input.ConfirmPassword" class="" autocomplete="new-password" aria-required="true" placeholder="password"/>
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <span asp-validation-for="Input.ConfirmPassword" class=""></span>
            </div>
            <button id="registerSubmit" type="submit" class="">Register</button>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
