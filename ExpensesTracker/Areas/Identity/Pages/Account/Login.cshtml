@page
@model LoginModel
@{
ViewData["Title"] = "Logowanie";
}

<div class="w-full h-full flex items-center justify-center">
    <section class="flex flex-col gap-2">
        <div class="text-center">
            <h2>Logowanie</h2>
        </div>
        <div class="pr-2 pl-2 flex justify-center">
            <hr class="w-48 h-1 bg-gray-100 border-0 rounded dark:bg-gray-700">
        </div>
        <form id="account" class="flex flex-col justify-center" method="post">
            <div asp-validation-summary="ModelOnly" class="" role="alert"></div>
            <div class="mb-2">
                <input asp-for="Input.Email" class="block w-full p-2.5 border border-gray-300 rounded" autocomplete="username" aria-required="true" placeholder="Email"/>
                <span asp-validation-for="Input.Email" class=""></span>
            </div>
            <div class="mb-2">
                <input asp-for="Input.Password" class="block w-full p-2.5 border border-gray-300 rounded" autocomplete="current-password" aria-required="true" placeholder="Hasło"/>
                <span asp-validation-for="Input.Password" class=""></span>
            </div>
            <div class="flex flex-row justify-between gap-8 mb-3">
                <label asp-for="Input.RememberMe" class="">
                    <input class="" asp-for="Input.RememberMe"/>
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
                <p>
                    <a id="forgot-password" asp-page="./ForgotPassword">Zapomniałeś hasła?</a>
                </p>
            </div>
            <div class="w-full flex justify-center items-center">
                <button id="login-submit" type="submit" class="block p-2.5 border border-gray-300 rounded-xl">Zaloguj się</button>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
